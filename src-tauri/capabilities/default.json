{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "magnet:*" }, { "url": "http:*" }, { "url": "https:*" }]
    },
    "store:default",
    "dialog:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "shell:allow-open",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": ["-Command", { "validator": "^Get-Process -Name \"[a-zA-Z0-9_\\-]+\" -ErrorAction SilentlyContinue \\| Select-Object -First 1$" }]
        }
      ]
    }
  ]
}
